{
  "name": "cv-website",
  "version": "1.0.0",
  "description": "Sitio web estático CV profesional para Cesar Fernando Ortiz Rocha",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:a11y": "jest --testPathPattern=a11y",
    "lint:html": "htmlhint index.html",
    "lint:css": "stylelint \"styles/**/*.css\"",
    "lint": "npm run lint:html && npm run lint:css"
  },
  "keywords": [
    "cv",
    "resume",
    "portfolio",
    "static-site"
  ],
  "author": "Cesar Fernando Ortiz Rocha",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/cli": "^4.8.0",
    "axe-core": "^4.8.0",
    "fast-check": "^3.15.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^23.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverageFrom": [
      "scripts/**/*.js",
      "!scripts/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
